    "@types/react-dom": "^18.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-next": "npm:@next/eslint-plugin-next@^16.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0",
    "vercel": "^37.0.0"
  }
