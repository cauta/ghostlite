{
  "name": "web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "npx @cloudflare/next-on-pages@latest",
    "preview": "pnpm pages:build && wrangler pages dev .vercel/output/static --d1 DB --r2 R2 --kv KV --compatibility-flag nodejs_compat",
