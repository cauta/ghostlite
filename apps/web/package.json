{
  "name": "web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build && npx @cloudflare/next-on-pages@latest",
    "preview": "pnpm build && wrangler pages dev .vercel/output/static --d1 DB --r2 R2 --kv KV --compatibility-flag nodejs_compat",
    "deploy": "pnpm build && wrangler pages deploy .vercel/output/static --project-name ghostlite",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "jose": "^5.9.0",
    "ulid": "^2.3.0",
    "@cloudflare/next-on-pages": "^1.13.7"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.0",
    "vercel": "^37.0.0"
  }
}
