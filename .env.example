# Local development overrides. The setup script sets the production values
# as Wrangler secrets. You only need this file if you want to run `pnpm dev`
# (Next.js dev server) against a local sqlite stub.

# Random hex string used to sign session tokens. Run: openssl rand -hex 32
JWT_SECRET=

# Random base64 string used as the Key Encryption Key for email provider API
# keys stored in D1. Run: openssl rand -base64 32
EMAIL_KEK=

# Used by `pnpm dev` only. In production, set via wrangler.toml [vars].
SITE_NAME="Ghostlite"
ACTIVE_THEME=default
